{
  "entities": {
    "Product": {
      "title": "Product",
      "description": "Store products for sale",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "price": { "type": "number" },
        "category": { "type": "string" },
        "rating": { "type": "number" },
        "image": { "type": "string" },
        "description": { "type": "string" },
        "isPreOrder": { "type": "boolean" }
      },
      "required": ["title", "price", "category", "rating", "image", "description"]
    },
    "Order": {
      "title": "Order",
      "description": "Customer orders",
      "type": "object",
      "properties": {
        "customerName": { "type": "string" },
        "customerPhone": { "type": "string" },
        "customerAddress": { "type": "string" },
        "total": { "type": "number" },
        "status": { "type": "string", "enum": ["Pending", "Shipped", "Delivered", "Cancelled"] },
        "date": { "type": "string" },
        "deliveryLocation": { "type": "string" },
        "deliveryCharge": { "type": "number" }
      },
      "required": ["customerName", "customerPhone", "customerAddress", "total", "status", "date"]
    }
  },
  "firestore": {
    "products/{productId}": {
      "schema": { "$ref": "#/entities/Product" },
      "description": "All public products"
    },
    "orders/{orderId}": {
      "schema": { "$ref": "#/entities/Order" },
      "description": "All customer orders"
    }
  }
}
